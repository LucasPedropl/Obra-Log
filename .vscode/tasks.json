{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Admin",
			"type": "npm",
			"script": "dev:admin",
			"isBackground": true,
			"problemMatcher": {
				"owner": "typescript",
				"pattern": "$tsc",
				"background": {
					"activeOnStart": true,
					"beginsPattern": "compiled",
					"endsPattern": "ready"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"serverReadyAction": {
				"pattern": "ready",
				"uriFormat": "http://localhost:3010",
				"action": "openExternally"
			}
		},
		{
			"label": "Start ERP",
			"type": "npm",
			"script": "dev:erp-next",
			"isBackground": true,
			"problemMatcher": {
				"owner": "typescript",
				"pattern": "$tsc",
				"background": {
					"activeOnStart": true,
					"beginsPattern": "compiled",
					"endsPattern": "ready"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"serverReadyAction": {
				"pattern": "ready",
				"uriFormat": "http://localhost:3005",
				"action": "openExternally"
			}
		},
		{
			"label": "Start All",
			"dependsOn": [
				"Start ERP",
				"Start Admin"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
